@using MirageQueue.Messages.Entities
@model MessageDetailViewModel

@{
    ViewData["Title"] = $"Message Detail - {Model.MessageType}";
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center mb-4">
    <div>
        <h1 class="h2 fw-bold mb-2">
            @if (Model.MessageType == "Inbound")
            {
                <i class="fas fa-inbox me-3 text-primary"></i>
            }
            else if (Model.MessageType == "Outbound")
            {
                <i class="fas fa-paper-plane me-3 text-success"></i>
            }
            else
            {
                <i class="fas fa-clock me-3 text-info"></i>
            }
            Message Detail
        </h1>
        <p class="text-muted">@Model.MessageType Message • @Model.Id</p>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-3 mt-lg-0">
        <a href="/mirage-dashboard/messages?type=@Model.MessageType.ToLower()" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Messages
        </a>
        @if (Model.CanRequeue)
        {
            <form method="post" action="/mirage-dashboard/requeue/@Model.Id?type=@Model.MessageType.ToLower()" class="d-inline">
                <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to requeue this message?')">
                    <i class="fas fa-redo me-2"></i>Requeue
                </button>
            </form>
        }
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center mb-4">
        <i class="fas fa-check-circle me-2"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="fas fa-exclamation-circle me-2"></i>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="row g-4">
    <!-- Basic Information -->
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-4">
                    <i class="fas fa-info-circle me-2"></i>Basic Information
                </h5>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Message ID</label>
                    <div class="bg-body-secondary p-3 rounded font-monospace small">
                        @Model.Id
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Message Contract</label>
                    <div class="bg-body-secondary p-3 rounded">
                        @Model.MessageContract
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Status</label>
                    <div>
                        <span class="status-badge badge fs-6
                            @(Model.Status == "DeadLettered" ? "bg-dark" :
                              Model.Status.Contains("Failed") ? "bg-danger" :
                              Model.Status.Contains("Processed") ? "bg-success" :
                              Model.Status.Contains("Processing") || Model.Status.Contains("Queued") ? "bg-warning" :
                              Model.Status.Contains("New") ? "bg-info" : "bg-secondary")">
                            @Model.Status
                        </span>
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Message Type</label>
                    <div class="bg-body-secondary p-3 rounded">
                        @Model.MessageType
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Timestamps & Additional Info -->
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-4">
                    <i class="fas fa-clock me-2"></i>Timestamps & Details
                </h5>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Created At</label>
                    <div class="bg-body-secondary p-3 rounded">
                        @Model.CreateAt.ToString("yyyy-MM-dd HH:mm:ss UTC")
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Updated At</label>
                    <div class="bg-body-secondary p-3 rounded">
                        @(Model.UpdateAt?.ToString("yyyy-MM-dd HH:mm:ss UTC") ?? "Not updated")
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ConsumerEndpoint))
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Consumer Endpoint</label>
                        <div class="bg-body-secondary p-3 rounded">
                            @Model.ConsumerEndpoint
                        </div>
                    </div>
                }

                @if (Model.MessageType == "Outbound")
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Attempts</label>
                        <div class="bg-body-secondary p-3 rounded">
                            @{
                                var detailAttemptBadge = Model.AttemptCount == 0 ? "bg-secondary"
                                    : Model.Status == "DeadLettered" ? "bg-dark"
                                    : Model.Status == "Failed" ? "bg-danger"
                                    : "bg-warning";
                            }
                            <span class="badge @detailAttemptBadge fs-6">@Model.AttemptCount</span>
                            @if (Model.Status == "DeadLettered")
                            {
                                <small class="text-muted ms-2">retry limit reached</small>
                            }
                        </div>
                    </div>

                    @if (Model.NextRetryAt.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Next Retry At</label>
                            <div class="bg-body-secondary p-3 rounded">
                                @Model.NextRetryAt.Value.ToString("yyyy-MM-dd HH:mm:ss UTC")
                                @{
                                    var delta = Model.NextRetryAt.Value - DateTime.UtcNow;
                                }
                                @if (delta > TimeSpan.Zero)
                                {
                                    <small class="text-muted ms-2">(in @((int)delta.TotalSeconds)s)</small>
                                }
                                else
                                {
                                    <small class="text-muted ms-2">(due)</small>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.ProcessingStartedAt.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Processing Started At</label>
                            <div class="bg-body-secondary p-3 rounded">
                                @Model.ProcessingStartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss UTC")
                            </div>
                        </div>
                    }
                }

                @if (Model.ExecuteAt.HasValue)
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Execute At</label>
                        <div class="bg-body-secondary p-3 rounded">
                            @Model.ExecuteAt.Value.ToString("yyyy-MM-dd HH:mm:ss UTC")
                        </div>
                    </div>
                }

                @if (Model.InboundMessageId.HasValue)
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Inbound Message ID</label>
                        <div class="bg-body-secondary p-3 rounded font-monospace small">
                            <a href="/mirage-dashboard/message/@Model.InboundMessageId?type=inbound" class="text-primary text-decoration-none">
                                @Model.InboundMessageId
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Error Details (only shown for failed messages) -->
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="card shadow-sm mt-4 border-danger">
        <div class="card-body">
            <h5 class="card-title mb-4 text-danger">
                <i class="fas fa-exclamation-triangle me-2"></i>Error Details
            </h5>

            @if (!string.IsNullOrEmpty(Model.ExceptionType))
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Exception Type</label>
                    <div class="bg-body-secondary p-3 rounded font-monospace small">
                        @Model.ExceptionType
                    </div>
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold">Error Message</label>
                <div class="bg-body-secondary p-3 rounded">
                    @Model.ErrorMessage
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.StackTrace))
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Stack Trace</label>
                    <div class="bg-body-secondary p-4 rounded">
                        <pre class="small overflow-auto mb-0" style="white-space: pre-wrap;">@Model.StackTrace</pre>
                    </div>
                </div>
            }
        </div>
    </div>
}

@* Error History (full per-attempt log, only for outbound rows that have one) *@
@if (Model.MessageType == "Outbound" && Model.ErrorHistory.Count > 0)
{
    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5 class="card-title mb-4">
                <i class="fas fa-history me-2"></i>Error History
                <small class="text-muted ms-2">@Model.ErrorHistory.Count @(Model.ErrorHistory.Count == 1 ? "attempt" : "attempts")</small>
            </h5>

            <div class="accordion" id="errorHistoryAccordion">
                @for (var i = 0; i < Model.ErrorHistory.Count; i++)
                {
                    var entry = Model.ErrorHistory[i];
                    var collapseId = $"errorHistory-{i}";
                    var sourceBadge = entry.Source == "Reaper" ? "bg-warning text-dark" : "bg-danger";

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <div class="d-flex flex-wrap align-items-center gap-2 w-100 pe-3">
                                    <span class="badge bg-secondary">Attempt @entry.Attempt</span>
                                    <span class="badge @sourceBadge">@entry.Source</span>
                                    <span class="small text-muted">@entry.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>
                                    <span class="ms-auto small text-truncate" style="max-width: 50%;">
                                        @(string.IsNullOrEmpty(entry.Message) ? "(no message)" : entry.Message)
                                    </span>
                                </div>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#errorHistoryAccordion">
                            <div class="accordion-body">
                                @if (!string.IsNullOrEmpty(entry.ExceptionType))
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Exception Type</label>
                                        <div class="bg-body-secondary p-2 rounded font-monospace small">@entry.ExceptionType</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(entry.Message))
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Message</label>
                                        <div class="bg-body-secondary p-2 rounded">@entry.Message</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(entry.StackTrace))
                                {
                                    <div class="mb-0">
                                        <label class="form-label fw-semibold">Stack Trace</label>
                                        <div class="bg-body-secondary p-3 rounded">
                                            <pre class="small overflow-auto mb-0" style="white-space: pre-wrap;">@entry.StackTrace</pre>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Message Content -->
<div class="card shadow-sm mt-4">
    <div class="card-body">
        <h5 class="card-title mb-4">
            <i class="fas fa-file-alt me-2"></i>Message Content
        </h5>

        <div class="bg-body-secondary p-4 rounded">
            <pre class="small overflow-auto" style="white-space: pre-wrap;">@Model.Content</pre>
        </div>
    </div>
</div>